# Meta (Facebook) Marketing API — powers the Platform Performance
# "Meta Ads Manager" row and the "Top Performing Campaigns" table.
# Copy this file to .env.local and fill in real values (do not commit it).

# Long-lived System User or Page access token with the ads_read permission.
META_ACCESS_TOKEN=

# Ad account id, with or without the "act_" prefix (e.g. act_1234567890).
META_AD_ACCOUNT_ID=

# Optional. Graph API version. Defaults to v21.0 if unset.
# META_API_VERSION=v21.0
